#  VIDEO GAME
:GameMap a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "processed/games_flat.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/videogame-ontology#game_{id}" ;
        rr:class :VideoGame
    ] ;
    rr:predicateObjectMap [
        rr:predicate schema:name ;
        rr:objectMap [ rml:reference "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :slug ;
        rr:objectMap [ rml:reference "slug" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate schema:datePublished ;
        rr:objectMap [ rml:reference "released" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :metacriticScore ;
        rr:objectMap [ rml:reference "metacritic" ; rr:datatype xsd:integer ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :playtime ;
        rr:objectMap [ rml:reference "playtime" ; rr:datatype xsd:integer ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :ratingsCount ;
        rr:objectMap [ rml:reference "ratings_count" ; rr:datatype xsd:integer ]
    ] .

#  AGGREGATE RATING  (one per game, IRI: rating_{game_id})
:AggregateRatingMap a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "processed/game_ratings.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/videogame-ontology#rating_{game_id}" ;
        rr:class :AggregateRating
    ] ;
    rr:predicateObjectMap [
        rr:predicate schema:ratingValue ;
        rr:objectMap [ rml:reference "rating_value" ; rr:datatype xsd:float ]
    ] .

:GameHasRatingMap a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "processed/game_ratings.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/videogame-ontology#game_{game_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate :hasRating ;
        rr:objectMap [
            rr:template "http://www.semanticweb.org/videogame-ontology#rating_{game_id}"
        ]
    ] .

#  ESRB RATING  (one individual per rating tier, IRI: esrb_{esrb_id})
:EsrbRatingMap a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "processed/game_esrb.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/videogame-ontology#esrb_{esrb_id}" ;
        rr:class :EsrbRating
    ] ;
    rr:predicateObjectMap [
        rr:predicate schema:name ;
        rr:objectMap [ rml:reference "esrb_name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :slug ;
        rr:objectMap [ rml:reference "esrb_slug" ; rr:datatype xsd:string ]
    ] .

:GameHasEsrbMap a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "processed/game_esrb.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/videogame-ontology#game_{game_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate :hasEsrbRating ;
        rr:objectMap [
            rr:template "http://www.semanticweb.org/videogame-ontology#esrb_{esrb_id}"
        ]
    ] .

#  RELATIONSHIP MAPS  (from join tables — no cross-source joins needed
#  because both sides use the same id-based IRI template)
# Game → Genre  (:hasGenre)
:GameGenreMap a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "processed/game_genres.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/videogame-ontology#game_{game_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate :hasGenre ;
        rr:objectMap [
            rr:template "http://www.semanticweb.org/videogame-ontology#genre_{genre_id}"
        ]
    ] .

# Game → Platform  (:availableOn)
:GamePlatformMap a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "processed/game_platforms.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/videogame-ontology#game_{game_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate :availableOn ;
        rr:objectMap [
            rr:template "http://www.semanticweb.org/videogame-ontology#platform_{platform_id}"
        ]
    ] .

# Game → ParentPlatform  (:hasParentPlatform — domain:VideoGame, triggers ConsoleGame inference)
:GameParentPlatformMap a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "processed/game_parent_platforms.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/videogame-ontology#game_{game_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate :hasParentPlatform ;
        rr:objectMap [
            rr:template "http://www.semanticweb.org/videogame-ontology#parentPlatform_{parent_platform_id}"
        ]
    ] .

