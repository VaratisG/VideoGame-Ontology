#  PUBLISHER
:PublisherMap a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "processed/publishers_flat.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/videogame-ontology#publisher_{id}" ;
        rr:class :Publisher
    ] ;
    rr:predicateObjectMap [
