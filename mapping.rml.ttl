@prefix rr:  <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:  <http://semweb.mmlab.be/ns/ql#> .
@prefix :    <http://www.semanticweb.org/videogame-ontology#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# IRI convention: <ontology-base>#<type>_<id>
# e.g.  :game_3498   :genre_4   :developer_405

#  GENRE
:GenreMap a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "processed/genres_flat.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/videogame-ontology#genre_{id}" ;
        rr:class :Genre
    ] ;
    rr:predicateObjectMap [
        rr:predicate schema:name ;
        rr:objectMap [ rml:reference "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :slug ;
        rr:objectMap [ rml:reference "slug" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :gamesCount ;
        rr:objectMap [ rml:reference "games_count" ; rr:datatype xsd:integer ]
    ] .

#  PLATFORM
:PlatformMap a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "processed/platforms_flat.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/videogame-ontology#platform_{id}" ;
        rr:class :Platform
    ] ;
    rr:predicateObjectMap [
        rr:predicate schema:name ;
        rr:objectMap [ rml:reference "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :slug ;
        rr:objectMap [ rml:reference "slug" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :yearStart ;
        rr:objectMap [ rml:reference "year_start" ; rr:datatype xsd:integer ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate :yearEnd ;
        rr:objectMap [ rml:reference "year_end" ; rr:datatype xsd:integer ]
    ] .

