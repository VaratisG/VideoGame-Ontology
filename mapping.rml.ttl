        ]
    ] .

# Platform → ParentPlatform  (:onParentPlatform — canonical domain-correct triples)
:PlatformParentMap a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "processed/platform_parent_platform.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/videogame-ontology#platform_{platform_id}"
    ] ;
    rr:predicateObjectMap [
        rr:predicate :onParentPlatform ;
        rr:objectMap [
            rr:template "http://www.semanticweb.org/videogame-ontology#parentPlatform_{parent_platform_id}"
        ]
    ] .
