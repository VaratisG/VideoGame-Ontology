    ] ;
    rr:predicateObjectMap [
        rr:predicate :storeDomain ;
        rr:objectMap [ rml:reference "domain" ; rr:datatype xsd:string ]
    ] .

#  TAG
:TagMap a rr:TriplesMap ;
