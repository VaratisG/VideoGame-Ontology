#  CREATOR
:CreatorMap a rr:TriplesMap ;
    rml:logicalSource [
        rml:source "processed/creators_flat.csv" ;
        rml:referenceFormulation ql:CSV
    ] ;
    rr:subjectMap [
        rr:template "http://www.semanticweb.org/videogame-ontology#creator_{id}" ;
        rr:class :Creator
    ] ;
    rr:predicateObjectMap [
